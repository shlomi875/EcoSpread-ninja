# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# e-shops.co.il REST API — used by /api/eshop/push to upsert products to the live store.
# If ESHOP_API_KEY is not set, the eShop endpoints return 503 and the UI shows
# "Not configured" instead of failing.
# Use a bare GUID only (no quotes). Coolify/Docker sometimes adds quotes — the server strips them.
ESHOP_API_KEY=
ESHOP_API_BASE=https://restapi.e-shops.co.il
#
# If health/push fail with HTTP 403 and "Cloudflare" in the error: restapi.e-shops.co.il is behind
# Cloudflare bot challenges; server-side fetch cannot solve them. Ask e-shops to allowlist your
# deployment's outbound IP or relax WAF for /api/* (see Swagger: same host as UI).
